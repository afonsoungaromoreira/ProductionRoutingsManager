{
  "_version": "1.37.0",
  "sap.app": {
    "id": "prodroutingmngfree",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.2"
    },
    "crossNavigation": {
      "inbounds": {
        "materialrouting-display": {
          "semanticObject": "materialrouting",
          "action": "display",
          "title": "{{appTitle}}",
          "subTitle": "",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.20.0",
      "toolsId": "875cbceb-a0ec-42c9-badf-869298581aff"
    },
    "dataSources": {
      "Z_POC_C_ROUTING_ACTL_TIME_CD_VAN": {
        "uri": "/sap/opu/odata/IWFND/CATALOGSERVICE;v=2/Annotations(TechnicalName='Z_POC_C_ROUTING_ACTL_TIME_CD_VAN',Version='0001')/$value/",
        "type": "ODataAnnotation",
        "settings": {
          "localUri": "localService/mainService/Z_POC_C_ROUTING_ACTL_TIME_CD_VAN.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata/sap/Z_POC_C_ROUTING_ACTL_TIME_CDS/",
        "type": "OData",
        "settings": {
          "annotations": [
            "Z_POC_C_ROUTING_ACTL_TIME_CD_VAN"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "fullWidth": true,
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.96.44",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "prodroutingmngfree.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {}
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "prodroutingmngfree.view",
        "controlAggregation": "pages",
        "controlId": "app",
        "clearControlAggregation": false
      },
      "routes": [
        {
          "name": "RoutingProposal",
          "pattern": ":?query:",
          "target": [
            "TargetRoutingProposal"
          ]
        }
      ],
      "targets": {
        "TargetRoutingProposal": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "RoutingProposal",
          "viewName": "RoutingProposal"
        }
      }
    },
    "rootView": {
      "viewName": "prodroutingmngfree.view.App",
      "type": "XML",
      "async": true,
      "id": "app"
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "prodroutingmngfree"
  }
}
