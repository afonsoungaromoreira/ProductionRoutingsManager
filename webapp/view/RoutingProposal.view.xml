<mvc:View 
    controllerName="prodroutingmngfree.controller.RoutingProposal"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    displayBlock="true">

    <f:DynamicPage id="dynamicPage" toggleHeaderOnTitleClick="true" headerExpanded="false">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Production Routings Manager" level="H3" titleStyle="H3"/>
                </f:heading>
                <f:navigationActions>
                    <Button icon="sap-icon://nav-back" type="Transparent" press=".onNavBack"/>
                </f:navigationActions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <HBox alignItems="Start" justifyContent="Start" class="sapUiContentPadding">
                    <Label text="Change material:" design="Bold" class="sapUiSmallMarginEnd" labelFor="materialSelect"/>
                    <Select id="materialSelect"
                        width="340px"
                        selectedKey="{viewModel>/Material}"
                        change=".onMaterialChange"
                        items="{viewModel>/Materials}">
                        <core:Item key="{viewModel>Material}" text="{viewModel>Label}"/>
                    </Select>
                </HBox>
                <HBox justifyContent="End" class="sapUiSmallMarginBottom">
                    <SegmentedButton id="viewToggle"
                        selectedKey="{viewModel>/ViewMode}"
                        selectionChange=".onViewModeChange">
                        <items>
                            <SegmentedButtonItem key="table"  icon="sap-icon://table-view"  text="Table View"/>
                            <SegmentedButtonItem key="single" icon="sap-icon://detail-view" text="Single View"/>
                        </items>
                    </SegmentedButton>
                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <VBox class="sapUiLargeMargin" fitContainer="true">

                <!-- Material Header -->
                <layout:VerticalLayout class="sapUiMediumMarginBottom" width="100%">
                    <VBox class="sapUiContentPadding sapUiSmallMarginBottom" alignItems="Center">
                        <Label text="Material" design="Bold" class="sapUiTinyMarginBottom"/>
                        <Title text="{viewModel>/Material}" level="H1" titleStyle="H1" class="sapUiTinyMarginBottom"/>
                        <Text text="{viewModel>/MaterialName}"/>
                    </VBox>
                </layout:VerticalLayout>

                <!-- View Toggle -->
                <!-- <HBox justifyContent="End" class="sapUiSmallMarginBottom">
                    <SegmentedButton id="viewToggle"
                        selectedKey="{viewModel>/ViewMode}"
                        selectionChange=".onViewModeChange">
                        <items>
                            <SegmentedButtonItem key="table"  icon="sap-icon://table-view"  text="Table View"/>
                            <SegmentedButtonItem key="single" icon="sap-icon://detail-view" text="Single View"/>
                        </items>
                    </SegmentedButton>
                </HBox> -->

                <!-- ═══════════════════════════════════════════════════════ TABLE VIEW -->
                <Panel id="tableViewPanel"
                    headerText="Production Routings"
                    visible="{= ${viewModel>/ViewMode} === 'table' }"
                    class="sapUiLargeMargin"
                    width="auto"
                    expandable="false"
                    backgroundDesign="Solid">
                    <content>
                        <VBox class="sapUiContentPadding">

                            <Table id="routingsTable"
                                items="{/Z_POC_C_ROUTING_ACTL_TIME}"
                                growing="true"
                                growingThreshold="20"
                                mode="None"
                                updateFinished=".onTableUpdateFinished"
                                width="auto">
                                <columns>
                                    <Column width="12%" minScreenWidth="Tablet" demandPopin="true">
                                        <Text text="Activity" class="sapUiSmallMarginBegin"/>
                                    </Column>
                                    <Column width="25%" minScreenWidth="Tablet" demandPopin="true">
                                        <Text text="Description" class="sapUiSmallMarginBegin"/>
                                    </Column>
                                    <Column width="28%" minScreenWidth="Tablet" demandPopin="true" hAlign="Begin">
                                        <Text text="Planned Times" class="sapUiSmallMarginBegin"/>
                                    </Column>
                                    <Column width="35%" minScreenWidth="Tablet" demandPopin="false" hAlign="Begin">
                                        <Text text="Proposed Times" class="sapUiSmallMarginBegin"/>
                                    </Column>
                                </columns>
                                <items>
                                    <ColumnListItem vAlign="Middle" type="Inactive">

                                        <VBox class="sapUiSmallMarginBegin sapUiSmallMarginTop sapUiSmallMarginBottom" justifyContent="Center">
                                            <ObjectNumber number="{Activity}" emphasized="true" state="Information"/>
                                        </VBox>

                                        <VBox class="sapUiSmallMarginBegin sapUiSmallMarginTop sapUiSmallMarginBottom">
                                            <Title text="{ActivityName}" level="H5" wrapping="true" class="sapUiSmallMarginBottom"/>
                                            <VBox class="sapUiTinyMarginTop">
                                                <Label text="Machine" design="Bold" class="sapUiTinyMarginTop"/>
                                                <Label text="Labor"   design="Bold" class="sapUiTinyMarginTop"/>
                                            </VBox>
                                        </VBox>

                                        <VBox class="sapUiSmallMarginBegin sapUiSmallMarginTop sapUiSmallMarginBottom">
                                            <ObjectNumber
                                                number="{parts:[{path:'PlanMachine'},{path:'PlanLabor'}],formatter:'.formatTotal'}"
                                                emphasized="true" state="Success" class="sapUiSmallMarginBottom"/>
                                            <VBox class="sapUiTinyMarginTop">
                                                <Text text="{PlanMachine} min" class="sapUiTinyMarginTop"/>
                                                <Text text="{PlanLabor} min"   class="sapUiTinyMarginTop"/>
                                            </VBox>
                                        </VBox>

                                        <VBox class="sapUiSmallMarginBegin sapUiSmallMarginTop sapUiSmallMarginBottom">
                                            <ObjectNumber
                                                number="{
                                                    parts:[
                                                        {path:'ProposedMachineTime'},{path:'ProposedLaborTime'},
                                                        {path:'RecommendedMachine'},{path:'RecommendedLabor'}
                                                    ],
                                                    formatter:'.formatProposedTotal'
                                                }"
                                                emphasized="true" state="Warning" class="sapUiSmallMarginBottom"/>
                                            <VBox class="sapUiTinyMarginTop">
                                                <HBox alignItems="Center">
                                                    <Input width="130px" type="Number"
                                                        value="{ProposedMachineTime}"
                                                        placeholder="{RecommendedMachine}"
                                                        change=".onProposedTimeChange"
                                                        class="sapUiTinyMarginTop">
                                                        <customData><core:CustomData key="selectOnFocus" value="true"/></customData>
                                                    </Input>
                                                    <Text text="min" class="sapUiSmallMarginBegin"/>
                                                </HBox>
                                                <HBox alignItems="Center">
                                                    <Input width="130px" type="Number"
                                                        value="{ProposedLaborTime}"
                                                        placeholder="{RecommendedLabor}"
                                                        change=".onProposedTimeChange"
                                                        class="sapUiTinyMarginTop">
                                                        <customData><core:CustomData key="selectOnFocus" value="true"/></customData>
                                                    </Input>
                                                    <Text text="min" class="sapUiSmallMarginBegin"/>
                                                </HBox>
                                            </VBox>
                                        </VBox>

                                    </ColumnListItem>
                                </items>
                            </Table>

                            <!-- Totals -->
                            <Panel headerText="Totals Summary" class="sapUiMediumMarginTop" backgroundDesign="Transparent">
                                <content>
                                    <HBox justifyContent="SpaceAround" alignItems="Center" class="sapUiContentPadding">
                                        <VBox alignItems="Center" class="sapUiLargeMarginEnd">
                                            <Label text="Total Planned" class="sapUiTinyMarginBottom"/>
                                            <ObjectNumber number="{viewModel>/TotalPlanned}" unit="min"
                                                emphasized="true" state="Success" class="sapUiMediumMarginTop"/>
                                        </VBox>
                                        <VBox alignItems="Center" class="sapUiLargeMarginBegin">
                                            <Label text="Total Proposed" class="sapUiTinyMarginBottom"/>
                                            <ObjectNumber number="{viewModel>/TotalProposed}" unit="min"
                                                emphasized="true" state="Warning" class="sapUiMediumMarginTop"/>
                                        </VBox>
                                    </HBox>
                                </content>
                            </Panel>

                            <!-- Action Buttons -->
                            <VBox alignItems="Center" class="sapUiLargeMarginTop sapUiLargeMarginBottom">
                                <HBox justifyContent="Center" width="100%" class="sapUiSmallMarginBottom">
                                    <Button id="acceptAllButton"
                                        text="Accept All Recommended Times"
                                        type="Ghost" icon="sap-icon://accept"
                                        press=".onAcceptAllPlannedTimes"
                                        visible="{= !${viewModel>/AcceptedAllApplied} }"
                                        width="300px" class="sapUiSmallMarginEnd"/>
                                    <Button id="revertAcceptAllButton"
                                        text="Revert All Proposed Times"
                                        type="Ghost" icon="sap-icon://decline"
                                        press="._onRevertAllProposedTimes"
                                        visible="{= ${viewModel>/AcceptedAllApplied} }"
                                        width="300px" class="sapUiSmallMarginEnd"/>
                                    <Button id="_IDGenButton"
                                        text="Save New Routing Times"
                                        type="Emphasized" icon="sap-icon://save"
                                        press=".onSaveNewRoutingTimes"
                                        width="300px"/>
                                </HBox>
                            </VBox>

                        </VBox>
                    </content>
                </Panel>

                <!-- ═══════════════════════════════════════════════════ SINGLE VIEW -->
                <Panel id="singleViewPanel"
                    headerText="Operation Entry"
                    visible="{= ${viewModel>/ViewMode} === 'single' }"
                    class="sapUiLargeMargin"
                    width="auto"
                    expandable="false"
                    backgroundDesign="Solid">
                    <content>
                        <VBox class="sapUiContentPadding">

                            <HBox width="100%" justifyContent="SpaceBetween" alignItems="Center" class="sapUiLargeMarginBottom">
                                <Title text="Material {viewModel>/Material} – {viewModel>/Plant}" level="H2" titleStyle="H2"/>
                            </HBox>

                            <HBox justifyContent="SpaceAround" class="sapUiSmallMarginBottom">
                                <Title level="H3" titleStyle="H3" text="{viewModel>/CurrentOperation/ActivityName}"/>
                            </HBox>

                            <HBox width="100%" justifyContent="SpaceBetween" alignItems="Center" class="sapUiLargeMarginBottom">
                                <Title text="Routings:" level="H4"/>
                                <HBox justifyContent="Center" alignItems="Center" class="sapUiSmallMarginEnd">
                                    <Button id="prevButton"
                                        icon="sap-icon://navigation-left-arrow" type="Transparent"
                                        press=".onPreviousOperation"
                                        enabled="{= ${viewModel>/CurrentOperationIndex} > 0 }"
                                        width="60px"/>
                                    <VBox alignItems="Center" class="sapUiSmallMarginBegin sapUiSmallMarginEnd">
                                        <Text text="{viewModel>/OperationCounter}" class="sapUiTinyMarginBottom"/>
                                        <Title text="Activity {viewModel>/CurrentOperation/Activity}" level="H3" titleStyle="H3"/>
                                    </VBox>
                                    <Button id="nextButton"
                                        icon="sap-icon://navigation-right-arrow" type="Transparent"
                                        press=".onNextOperation"
                                        enabled="{= ${viewModel>/CurrentOperationIndex} &lt; ${viewModel>/TotalOperations} - 1 }"
                                        width="60px"/>
                                </HBox>
                            </HBox>

                            <!-- Time grid -->
                            <VBox width="100%" class="sapUiLargeMarginTop">

                                <!-- Column headers -->
                                <HBox width="100%" class="sapUiMediumMarginBottom">
                                    <VBox width="20%"/>
                                    <VBox width="20%" alignItems="Center">
                                        <Label text="Machine" design="Bold"/>
                                    </VBox>
                                    <VBox width="20%" alignItems="Center">
                                        <Label text="Labor" design="Bold"/>
                                    </VBox>
                                    <VBox width="20%" alignItems="Center">
                                        <Label text="Total" design="Bold"/>
                                    </VBox>
                                </HBox>

                                <!-- Planned row: ObjectNumber (green, emphasized) + plain Text values — same as table view -->
                                <HBox width="100%" class="sapUiMediumMarginBottom" alignItems="Center">
                                    <VBox width="20%">
                                        <Label text="Planned" design="Bold"/>
                                    </VBox>
                                    <!-- Machine planned -->
                                    <VBox width="20%" alignItems="Center">
                                        <VBox alignItems="Center">
                                            <ObjectNumber
                                                number="{viewModel>/CurrentOperation/PlanMachine}"
                                                unit="min"
                                                emphasized="true" 
                                                state="Success"/>
                                        </VBox>
                                    </VBox>
                                    <!-- Labor planned -->
                                    <VBox width="20%" alignItems="Center">
                                        <VBox alignItems="Center">
                                            <ObjectNumber
                                                number="{viewModel>/CurrentOperation/PlanLabor}"
                                                unit="min"
                                                emphasized="true"
                                                state="Success"/>
                                        </VBox>
                                    </VBox>
                                    <!-- Total planned -->
                                    <VBox width="20%" alignItems="Center">
                                        <ObjectNumber
                                            number="{
                                                parts:[
                                                    {path:'viewModel>/CurrentOperation/PlanMachine'},
                                                    {path:'viewModel>/CurrentOperation/PlanLabor'}
                                                ],
                                                formatter:'.formatCurrentOperationTotal'
                                            }"
                                            emphasized="true"
                                            state="Success"/>
                                    </VBox>
                                </HBox>

                                <!-- Proposal row -->
                                <HBox width="100%" class="sapUiLargeMarginBottom" alignItems="Center">
                                    <VBox width="20%">
                                        <Label text="Proposal" design="Bold"/>
                                    </VBox>
                                    <!-- Machine input -->
                                    <VBox width="20%" alignItems="Center">
                                        <HBox alignItems="Center">
                                            <Input id="machineInput" type="Number" width="120px" textAlign="End"
                                                value="{viewModel>/CurrentOperation/ProposedMachineTime}"
                                                change=".onSingleViewTimeChange">
                                                <customData>
                                                    <core:CustomData key="selectOnFocus" value="true"/>
                                                    <core:CustomData key="timeType"      value="ProposedMachineTime"/>
                                                </customData>
                                            </Input>
                                            <Text text="min" class="sapUiSmallMarginBegin"/>
                                        </HBox>
                                    </VBox>
                                    <!-- Labor input -->
                                    <VBox width="20%" alignItems="Center">
                                        <HBox alignItems="Center">
                                            <Input id="laborInput" type="Number" width="120px" textAlign="End"
                                                value="{viewModel>/CurrentOperation/ProposedLaborTime}"
                                                change=".onSingleViewTimeChange">
                                                <customData>
                                                    <core:CustomData key="selectOnFocus" value="true"/>
                                                    <core:CustomData key="timeType"      value="ProposedLaborTime"/>
                                                </customData>
                                            </Input>
                                            <Text text="min" class="sapUiSmallMarginBegin"/>
                                        </HBox>
                                    </VBox>
                                    <!-- Total proposed — orange, falls back to Recommended when empty -->
                                    <VBox width="20%" alignItems="Center">
                                        <ObjectNumber
                                            number="{
                                                parts:[
                                                    {path:'viewModel>/CurrentOperation/ProposedMachineTime'},
                                                    {path:'viewModel>/CurrentOperation/ProposedLaborTime'},
                                                    {path:'viewModel>/CurrentOperation/RecommendedMachine'},
                                                    {path:'viewModel>/CurrentOperation/RecommendedLabor'}
                                                ],
                                                formatter:'.formatProposedTotal'
                                            }"
                                            emphasized="true"
                                            state="Warning"/>
                                    </VBox>
                                </HBox>

                            </VBox>

                            <!-- Action Buttons -->
                            <HBox justifyContent="Center" width="100%" class="sapUiSmallMarginBottom">
                                <Button id="acceptAllButton2"
                                    text="Accept All Recommended Times"
                                    type="Ghost" icon="sap-icon://accept"
                                    press=".onAcceptAllPlannedTimes"
                                    visible="{= !${viewModel>/AcceptedAllApplied} }"
                                    width="300px" class="sapUiSmallMarginEnd"/>
                                <Button id="revertAcceptAllButton2"
                                    text="Revert All Proposed Times"
                                    type="Ghost" icon="sap-icon://decline"
                                    press="._onRevertAllProposedTimes"
                                    visible="{= ${viewModel>/AcceptedAllApplied} }"
                                    width="300px" class="sapUiSmallMarginEnd"/>
                                <Button id="_IDGenButton2"
                                    text="Save New Routing Times"
                                    type="Emphasized" icon="sap-icon://save"
                                    press=".onSaveNewRoutingTimes"
                                    width="300px"/>
                            </HBox>

                        </VBox>
                    </content>
                </Panel>

            </VBox>
        </f:content>

    </f:DynamicPage>
</mvc:View>